<%- include('../partials/header', { title: 'Danh sách user' }); %>
<% if (typeof message !== 'undefined' && message) { %>
<div class="alert alert-success alert-dismissible fade show">
    <%= message %>
    <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
</div>
<% } %>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Danh sách người dùng</h1>
    <a href="/crud" class="btn btn-primary">+ Thêm mới</a>
</div>
<% if (!datalist.length) { %>
<p class="text-muted">Chưa có dữ liệu. <a href="/crud">Tạo người dùng đầu tiên</a>.</p>
<% } else { %>
<div class="table-responsive bg-white shadow-sm rounded">
    <table class="table table-striped table-hover mb-0">
        <thead class="thead-light">
            <tr>
                <th>Email</th>
                <th>Họ</th>
                <th>Tên</th>
                <th>Địa chỉ</th>
                <th>Giới tính</th>
                <th>Vai trò</th>
                <th>Điện thoại</th>
                <th>Avatar</th>
                <th width="140">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% for (let i = 0; i < datalist.length; i++) { %>
                <tr>
                    <td><%= datalist[i].email %></td>
                    <td><%= datalist[i].firstName %></td>
                    <td><%= datalist[i].lastName %></td>
                    <td><%= datalist[i].address || '—' %></td>
                    <td><%= (datalist[i].gender == 1 || datalist[i].gender === true) ? 'Nữ' : 'Nam' %></td>
                    <td><%= datalist[i].roleId %></td>
                    <td><%= datalist[i].phone || '—' %></td>
                    <td><%= datalist[i].avatar || '—' %></td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="/edit-crud?id=<%= datalist[i].id %>">Sửa</a>
                        <a class="btn btn-sm btn-outline-danger" href="/delete-crud?id=<%= datalist[i].id %>" onclick="return confirm('Xóa người dùng này?');">Xóa</a>
                    </td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
<% } %>
<%- include('../partials/footer'); %>
